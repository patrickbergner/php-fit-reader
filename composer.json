{
    "name": "emontis/fit-reader",
    "description": "Library for reading Garmin FIT activity files",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "activity",
        "csv",
        "cycling",
        "fit",
        "fitness",
        "garmin",
        "gps",
        "gpx",
        "kml",
        "running",
        "tcx",
        "track",
        "tracking",
        "training"
    ],
    "homepage": "https://github.com/patrickbergner/php-fit-reader",
    "authors": [
        {
            "name": "Patrick Bergner",
            "homepage": "https://github.com/patrickbergner",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^13"
    },
    "autoload": {
        "psr-4": {
            "Emontis\\FitReader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Emontis\\FitReader\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/generate-default-samples",
        "bin/generate-profile"
    ],
    "scripts": {
        "analyze": "phpstan analyse",
        "test": "phpunit --testsuite unit"
    },
    "minimum-stability": "stable"
}
